{
  "name": "service-jobs-project",
  "version": "0.1.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/a-novel/service-jobs.git"
  },
  "license": "AGPL-3.0",
  "type": "module",
  "workspaces": [
    "."
  ],
  "scripts": {
    "format": "pnpm format:go && pnpm format:proto && pnpm format:js",
    "format:go": "go mod tidy && go tool -modfile=golangci-lint.mod golangci-lint run ./... --fix",
    "format:js": "prettier --write . --config prettier.config.ts",
    "format:proto": "go tool -modfile=buf.mod buf format -w && go tool -modfile=buf.mod buf dep update",
    "generate": "pnpm run generate:go",
    "generate:go": "go generate ./...",
    "preinstall": "npx only-allow pnpm",
    "lint": "pnpm lint:go && pnpm lint:proto && pnpm lint:js",
    "lint:ci": "pnpm i && pnpm lint:js",
    "lint:eslint": "eslint .",
    "lint:go": "go tool -modfile=golangci-lint.mod golangci-lint run ./...",
    "lint:js": "pnpm lint:stylecheck && pnpm lint:eslint",
    "lint:proto": "go tool -modfile=buf.mod buf lint",
    "lint:stylecheck": "prettier --check . --config prettier.config.ts",
    "prepublish:doc": "pnpm prepublish:doc:readme",
    "prepublish:doc:readme": "a-novel publish stamp 'a-novel/service-jobs/[a-z0-9/-]+:' README.md"
  },
  "devDependencies": {
    "@a-novel-kit/nodelib-browser": "^1.3.18",
    "@a-novel-kit/nodelib-config": "^1.3.18",
    "@a-novel-kit/nodelib-test": "^1.3.18",
    "@eslint/js": "^10.0.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^24.10.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-storybook": "^10.2.8",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.0.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.0",
    "prettier": "^3.6.2",
    "prettier-plugin-packagejson": "^3.0.0",
    "prettier-plugin-sql": "^0.20.0",
    "typescript-eslint": "^8.46.4"
  },
  "packageManager": "pnpm@11.15.1",
  "engines": {
    "node": ">=23.11.0",
    "npm": ">=10.9.2"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
